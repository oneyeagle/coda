		<band height="646">
			<staticText>
				<reportElement x="4" y="37" width="276" height="106" uuid="09ab91d2-e0f8-43a8-a092-5f4abba7366d">
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.leftIndent" value="px"/>
				</reportElement>
				<box padding="0">
					<pen lineWidth="1.0" lineStyle="Dotted"/>
					<topPen lineWidth="0.0" lineStyle="Solid"/>
					<leftPen lineWidth="1.0" lineStyle="Solid"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid"/>
					<rightPen lineWidth="1.0" lineStyle="Solid"/>
				</box>
				<textElement textAlignment="Left" verticalAlignment="Middle">
					<font fontName="DejaVu Sans" size="10" isBold="false" isUnderline="false"/>
					<paragraph leftIndent="4"/>
				</textElement>
				<text><![CDATA[Le présent Crédit ne sera mis à la disposition de l'Emprunteur qu'après réalisation des conditions suivantes :
- L’accord de la PPR confirmant qu’elle procédera au prélèvement à la source du montant de l’échéance convenue.
- Signature de l’engagement de cession de créance prévu par la convention PPR
- Constitution  des garanties convenues ci-dessus.   ]]></text>
			</staticText>
			<componentElement>
				<reportElement x="4" y="143" width="552" height="31" uuid="8c14e2a7-72ce-4bb1-892e-c2771036bf20"/>
				<jr:list xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports/components http://jasperreports.sourceforge.net/xsd/components.xsd" printOrder="Vertical">
