			<staticText>
				<reportElement x="282" y="644" width="266" height="56" uuid="af1d0098-78c0-4426-ad9a-5eb15ba48fcd"/>
				<box padding="0">
					<pen lineWidth="1.0" lineStyle="Dotted"/>
					<topPen lineWidth="0.0" lineStyle="Solid"/>
					<leftPen lineWidth="0.0" lineStyle="Solid"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid"/>
					<rightPen lineWidth="0.0" lineStyle="Solid"/>
				</box>
				<textElement textAlignment="Right">
					<font fontName="DejaVu Sans" size="10" isBold="false" isUnderline="false"/>
				</textElement>
				<text><![CDATA[اذا كان سعر الفائدة متغير، فإن المقترض يقبل صراحة بمبدأ التغيير، و يعلن انخراطه بدون شرط في معادلة تحديده المبينة على أساس التغير السنوي لمتوسط السعر المرجعي المباين البنوكي كما يحدد خلال دوريات بنك المغرب طبقا لمراسيم وزير ]]></text>
			</staticText>
			<staticText>
				<reportElement x="4" y="641" width="272" height="59" uuid="64afca51-b91f-4d88-8a47-07d53d48ee09"/>
				<box padding="0">
					<pen lineWidth="1.0" lineStyle="Dotted"/>
					<topPen lineWidth="0.0" lineStyle="Solid"/>
					<leftPen lineWidth="0.0" lineStyle="Solid"/>
					<bottomPen lineWidth="0.0" lineStyle="Solid"/>
					<rightPen lineWidth="0.0" lineStyle="Solid"/>
				</box>
				<textElement>
					<font fontName="DejaVu Sans" size="10" isBold="false" isUnderline="false"/>
				</textElement>
				<text><![CDATA[Si le taux d’intérêt est variable, l’Emprunteur accepte expressément le principe de sa variabilité et déclare adhérer sans réserve à la formule de sa détermination sur la base de la variation ]]></text>
			</staticText>
