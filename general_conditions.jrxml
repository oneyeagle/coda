			<staticText>
				<reportElement x="284" y="463" width="266" height="77" uuid="7a91719e-46f3-4354-8a30-7460c9b0c0f4"/>
				<box padding="0">
					<pen lineWidth="1.0" lineStyle="Dotted"/>
					<topPen lineWidth="0.0" lineStyle="Solid"/>
					<leftPen lineWidth="0.0" lineStyle="Solid"/>
