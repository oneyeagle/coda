				<text><![CDATA[الفصل 2: استعمال مبلغ القرض]]></text>
			</staticText>
			<staticText>
				<reportElement x="278" y="684" width="276" height="19" uuid="8292ac9b-e8e8-49c9-b49b-13a3fd04ce52"/>
				<box padding="0">
					<pen lineWidth="1.0" lineStyle="Dotted"/>
					<topPen lineWidth="0.0" lineStyle="Solid"/>
