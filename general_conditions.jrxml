				</textElement>
				<text><![CDATA[شـروط عامـة]]></text>
			</staticText>
			<staticText>
				<reportElement x="301" y="64" width="235" height="24" uuid="46d3c6ff-fef3-4ccb-9cb5-5f8426a5565a"/>
				<box padding="0">
					<pen lineWidth="1.0" lineStyle="Dotted"/>
					<topPen lineWidth="0.0" lineStyle="Solid"/>
					<leftPen lineWidth="0.0" lineStyle="Solid"/>
