		<band height="80" splitType="Stretch">
			<frame>
				<reportElement x="0" y="0" width="535" height="80" uuid="a5b6c7d8-e9f0-4056-2c3d-4e5f6a7b8c9d"/>
				<componentElement>
					<reportElement x="0" y="0" width="535" height="80" uuid="b6c7d8e9-f0a1-4057-3d4e-5f6a7b8c9d0e"/>
					<jr:list xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports/components http://jasperreports.sourceforge.net/xsd/components.xsd" printOrder="Vertical">
						<datasetRun subDataset="Rank" uuid="c7d8e9f0-a1b2-4058-4e5f-6a7b8c9d0e1f">
							<dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.data.JRBeanCollectionDataSource($F{propertyRanks})]]></dataSourceExpression>
						</datasetRun>
						<jr:listContents height="80" width="535">
							<frame>
								<reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="535" height="80" uuid="d8e9f0a1-b2c3-4059-5f6a-7b8c9d0e1f2a"/>
								<frame>
									<reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="267" height="80" uuid="e9f0a1b2-c3d4-4060-6a7b-8c9d0e1f2a3b"/>
									<box>
										<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
										<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
										<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
										<rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
									</box>
									<textField textAdjust="StretchHeight">
										<reportElement x="5" y="5" width="255" height="75" uuid="a1b2c3d4-e5f6-4062-8c9d-0e1f2a3b4c5d"/>
										<textElement>
											<font fontName="DejaVu Sans" size="9" isBold="false"/>
										</textElement>
										<textFieldExpression><![CDATA["La Caution consent, conformément aux dispositions du dahir du 22 novembre 2011, au profit de la BANQUE qui accepte par privilège  et préférence à tous autres créanciers une hypothèque en rang "+$F{rang}+ "à concurrence d’un montant en capital de "+$F{mt}+ " outre les intérêts, commissions, frais est accessoires"]]></textFieldExpression>
									</textField>
								</frame>
								<frame>
									<reportElement stretchType="RelativeToTallestObject" x="268" y="0" width="267" height="80" uuid="e5f6a7b8-c9d0-4066-2a3b-4c5d6e7f8a9b"/>
									<staticText>
										<reportElement x="6" y="5" width="257" height="65" uuid="f6a7b8c9-d0e1-4067-3b4c-5d6e7f8a9b0c"/>
										<textElement textAlignment="Right">
											<font fontName="DejaVu Sans" size="9"/>
										</textElement>
										<text><![CDATA[يمنـــــح الكفــــيــــل طبقــــــــا لمقتضيـــــــات ظهيــــــر 22 نوفمبر 2011  لفـــائـــــدة البنـــــك الـــــذي يقبــــــل بالامتيـــــاز وبالأفضليـــــة علــــى جميــــــــع الدائنين الآخرين ، رهنــا رسميــا مــن الدرجـة  ....... فـي حـدود مبلغ أصل الدين  ........ بالإضافـة إلــى الفـوائـــد والعمـــولات والمصاريــف والتوابــع، ]]></text>
									</staticText>
								</frame>
							</frame>
						</jr:listContents>
					</jr:list>
				</componentElement>
			</frame>
		</band>
		<band height="90" splitType="Stretch">
			<frame>
				<reportElement x="0" y="0" width="535" height="90" uuid="49d51825-33b5-443d-a840-7a8032471b32"/>
				<frame>
					<reportElement x="0" y="0" width="267" height="90" uuid="97ff9037-0a03-423a-b038-a81503eefbd5"/>
					<box>
						<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					</box>
					<staticText>
						<reportElement x="5" y="5" width="255" height="80" uuid="66bad452-6681-4155-836d-a91d98a6b9a9"/>
						<textElement textAlignment="Justified">
							<font fontName="DejaVu Sans" size="10"/>
						</textElement>
						<text><![CDATA[Sur l’(ou les) immeuble(s) désigné(s) ci-après pour garantir tant le remboursement du montant en capital du (ou des) présent(s)
crédit(s), ainsi que le paiement des intérêts d’une année et de l’année courante en vertu de l’article 168 du Dahir précité.
]]></text>
					</staticText>
				</frame>
				<frame>
					<reportElement x="268" y="0" width="267" height="90" uuid="4fb91402-7bde-47d8-b4bd-047442185708"/>
					<staticText>
						<reportElement x="7" y="0" width="255" height="80" uuid="2fbbf0e0-9a05-40e0-b527-b93668b24fbd">
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement textAlignment="Right">
							<font fontName="DejaVu Sans" size="10"/>
						</textElement>
						<text><![CDATA[على مجمــوع العقــار أو العقــارات المعينــة فيمـا يلــي، مــن أجــل ضمــان تســديــد مبلــغ الرأسمــال هــذا القــرض أو لأي سبــب اخــر، بالإضافـــة إلى تســديــد الفــوائــد لسنــة واحـــدة وللسنـــة الجاريـــة طبقـــا لمقتضيـــات المــادة 168 من الظهيــر السالـــف الذكـــر.]]></text>
					</staticText>
				</frame>
			</frame>
		</band>
		<band height="215" splitType="Stretch">
			<frame>
				<reportElement x="0" y="0" width="535" height="215" uuid="6b360b67-addd-45ec-847c-f009b79cf5ce"/>
				<frame>
					<reportElement x="0" y="0" width="267" height="215" uuid="36e8fa8a-38db-47b1-bac0-32ec68a80512"/>
					<box>
						<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					</box>
					<staticText>
						<reportElement x="5" y="0" width="255" height="215" uuid="5213a935-509e-4668-a991-78242d7082c5"/>
						<textElement textAlignment="Justified">
							<font fontName="DejaVu Sans" size="9"/>
						</textElement>
						<text><![CDATA[Sont compris dans l’affectation hypothécaire, les biens immobiliers ci-après désignés, tels qu’ils existent, y compris toutes dépendances, toutes les constructions qui seront édifiées, tous droits y attachés, tous immeubles par destination en dépendant ou pouvant en dépendre et toutes améliorations et accroissements que la Caution  pourrait faire.
La Caution s’engage à maintenir les constructions en bon état et à effectuer toutes les réparations nécessaires à la conservation des immeubles, la BANQUE pourra à toute époque faire constater l’état des biens hypothéqués par les personnes de son choix aux frais de l’EMPRUNTEUR ou de la Caution qui s’y obligent.
La Caution s’interdit sans l’accord de la Banque d’affecter l’(ou les) immeuble(s) hypothéqué(s) en faveur de la BANQUE  à un usage commercial, de le rattacher à un fonds de commerce, d’y constituer un fonds de commerce ou d’y domicilier toute personnes physique ou morale]]></text>
					</staticText>
				</frame>
				<frame>
					<reportElement x="268" y="0" width="267" height="215" uuid="bcd4ee01-636b-4bdb-a96d-cf1975b2cdf7"/>
					<staticText>
						<reportElement x="7" y="0" width="255" height="215" uuid="51746c5b-91e9-4b42-820b-390a2fa68dd0"/>
						<textElement textAlignment="Right">
							<font fontName="DejaVu Sans" size="9"/>
						</textElement>
						<text><![CDATA[ويدخل ضمن التخصيص الرهني، الملك أو الممتلكات العقارية المعينة فيما يلي، كما هي موجودة، بما فيها جميع المرافق وكل البناءات التي سيتم تشييدها، وكل الحقوق المرتبطة بها، وكل العقارات التابعة لها بالتخصيص أو التي يمكن أن تصبح تابعة لها وكذا جميع التحسينات والإضافات التي يمكن أن يدخلها عليها للمقترض.


يلتزم الكفيـــل بالمحافظـــة على البنايات في حالـــة جيدة وبالقيام بكافـة الإصلاحات الضرورية للحفاظ على العقارات، حيث يمكن للبنـــك في أية لحظة القيـــــام بمعاينــــة حالـــة الأملاك المرهونة رسميا بواسطــة أشخاص من اختياره على نفقة للمقترض أو الكفيل  الذين يلتزمون بذلك..

يمتنع الكفيل عن تخصيص العقار أو العقارات المرهونة رسميا لفائدة البنك للاستعمال التجاري، أو إلحاقها بأصل تجاري أو تأسيس أصل تجاري عليها ، أو توطين أي شخص ذاتي أو معنوي  في هذا العقار.
]]></text>
					</staticText>
				</frame>
			</frame>
		</band>
		<band height="639" splitType="Stretch">
			<frame>
				<reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="535" height="639" uuid="b2345678-9abc-def0-1234-012345678976"/>
				<frame>
					<reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="267" height="639" uuid="c3456789-abcd-ef01-2345-012345678977"/>
					<box>
						<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					</box>
					<staticText>
						<reportElement x="5" y="5" width="255" height="624" uuid="d456789a-bcde-f012-3456-012345678978"/>
						<textElement textAlignment="Justified">
							<font fontName="DejaVu Sans" size="9"/>
						</textElement>
						<text><![CDATA[La Caution s’interdit de donner en location l’(ou les) immeuble(s) hypothéqué(s) en faveur de la BANQUE sans l’accord préalable et écrit de cette dernière.
En cas de location dûment autorisée par la BANQUE, la Caution  déclare d’ores et déjà céder, déléguer  et transporter au profit de la BANQUE tous loyers et revenus de l’(ou les) immeubles grevé (s) d’hypothèque
 en conséquence il subroge la banque dans tous ses droits et actions vis à vis de ses locataires, lesquels sont autorisés à se libérer de tous loyers directement entre les mains de la BANQUE par préférence et antériorité à tous  autres créanciers et à lui-même sur simple quittance de celle-ci  et hors la présence de la Caution.
Néanmoins, notification de cette délégation et de cette subrogation ne sera faite aux locataires qu’en cas de défaut de paiement de toutes sommes dues et exigibles en capital, intérêts, commission, frais et accessoires, ou en cas d’inexécution de l’une des clauses et conditions du présent contrat.
La Caution déclare :

- que les immeubles par destination dépendant de la (ou des) propriété(s) désignée(s) ci-après ne sont pas nantis au                          profit d’un autre créancier et il s’engage expressément à ne pas les nantir sans l’autorisation expresse et par écrit de la BANQUE,

-qu’il n’existe sur la (ou les) propriété(s) hypothéquée(s) ni clause de résolution ou de rescision, ni de servitude, ni opposition, ni hypothèque conventionnelle ou forcée, ni aucun droit de nature à porter atteinte à l’hypothèque ci-dessus consentie.


LA CAUTION autorise :
dès à présent la BANQUE, sans qu'il puisse en résulter aucune réduction de ses engagements, à donner son adhésion à tous atermoiements ou prorogations d’échéances et à tous concordats amiables ou judiciaires que la BANQUE pourrait être amenée à consentir, de même la CAUTION ne pourra se prévaloir d'aucune subrogation à l'occasion des paiements qu'elle effectuerait à la BANQUE avant qu’elle n’ait été intégralement remboursée de ses créances  en capital outre les intérêts, commissions, frais et accessoires sur l’EMPRUNTEUR.

Le présent cautionnement ne se confondra pas avec les autres cautionnements et généralement toutes garanties quelconques qui ont pu ou pourront être données par la CAUTION ou tous autres.]]></text>
					</staticText>
				</frame>
				<frame>
					<reportElement stretchType="RelativeToTallestObject" x="268" y="0" width="267" height="639" uuid="f6789abc-def0-1234-5678-012345678980"/>
					<staticText>
						<reportElement x="7" y="5" width="255" height="623" uuid="0789abcd-ef01-2345-6789-012345678981"/>
						<textElement textAlignment="Right">
							<font fontName="DejaVu Sans" size="9"/>
						</textElement>
						<text><![CDATA[ يمتنع الكفيل عن منح العقار أو العقارات المرهونة رسميا لفائدة البنك على سبيل الكراء، بدون الموافقة المسبقة والمكتوبة من البنك .

في حالة كراء مرخص به كتابة من طرف البنك، يصرح الكفيل، منذ الآن، بتفويت وإنابة وتحويل جميع أكرية ومداخيل العقار أو العقارات المثقلة بالرهون الرسمية، لفائدة البنك.

ونتيجة لذلك، فإن البنك يحل محله في جميع حقوقه ودعاواه تجاه مكتريه، ويعتبر هؤلاء المكترين مخولين صراحة بمقتضى هذا العقد، بأداء الأكرية مباشرة بين يدي البنك بالأفضلية وبالأسبقية على جميع الدائنين الآخرين بل وبالأسبقية عليه هو نفسه بناء على مجرد وصل من هذا البنك وفي غياب الكفيل.


إلا أن تبليغ هذه الإنابة إلى المكترين، وحلول البنك محل المقترض، لن يتم إلا في حالة عدم أداء المبالغ المستحقة والتي حل أجلها رأسمالا وفوائد وعمولات ومصاريف وتوابع،  أو في حالة عدم تنفيذ أحد بنود أو شروط هذا العقد.

يصرح الكفيل:

- بأن البنايات التابعة بالتخصيص للملكية أو الأملاك المعينة أسفله، غير مرهونة لفائدة دائن آخر، ويتعهد صراحة بعدم رهنها بدون موافقة صريحة ومكتوبة من البنك

- أنه لا يوجد على الملكية أو الأملاك المرهونة رسميا أي شرط فاسخ أو مبطل، ولا أي ارتفاقات،  كما لا يوجد أي تعرض  أو رهن رسمي اتفاقي أو إجباري، أو أي حق من شأنه أن يمس بالرهن الرسمي الممنوح أعلاه

و يرخـــص الكفــيــل:
 من الآن للبنك ودون أن ينتـــج عـــن ذلك أي نقصـــان لإلتزاماتـــــه أن يمنح موافقته على أي إمهـــــال أو تمــديــد للإستحقاقات وكـــذا أي صلــــح ودي أو قضـــائي، يمكن أن يمنحــــه البنــــــك للمقتــــــرض، كمـــــا لا يمكــــــن للكفيـــل أن يستفيـــد مـــن أي حلـــــول بمناسبـــة الأداءات التي سيقــــــوم بها لفائـــــــدة البنــــك، وذلك إلى حين التسديد الكلي لديون  المقترض، كيفما كان نوعها و لأي سبب كانت، بمــــا فيهـــا الأصــــل زيادة على الفــــوائد والمصاريف و العمــــولات و التوابـــع

تستقل هذه الكفالة عن باقي الكفالات الأخرى، و بصفة عامة عن مختلف الضمانات التي يمكن أن يقدمها أو سبق أن قدمها الكفيل أو غيره
]]></text>
					</staticText>
				</frame>
			</frame>
		</band>
		<band height="20" splitType="Stretch">
