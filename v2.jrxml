<?xml version="1.0" encoding="UTF-8"?>
<!--
  Leaf_Grey minimalist AFTER v2 — faithful to production structure.

  Mirrors your production template definition for the Customer subDataset:
    - subDataset uuid preserved (57a54224-…)
    - Same dataset feeding pattern (Collection field wrapped at runtime)
    - Same <frame style="Detail"> with 4-pen 1.0 border
    - customerName lives OUTSIDE the frame (production quirk: it's the
      "header" field with mode=Transparent + markup=styled)
    - customerAddress lives INSIDE the frame (production behavior)
    - French labels (left), colons (middle), Arabic labels (right) sit
      OUTSIDE the frame, overlapping its borders, exactly like production
    - Same fonts: DejaVu Sans, sizes 9 / 10 / default, isBold flags, paragraphs
    - Same box pens (left 0.75 / bottom 1.0 for French labels; bottom 1.0
      for value fields; rightPen 1.0 for the row-1 Arabic label cap)

  The dot-leader application:
    - Two static <staticText> dot strips (uuids d279da75-… and 52008247-…
      in your production) are DELETED.
    - Two value <textFieldExpression>s now produce  value + dynamic_dots
      sized from each field's own width using your file's existing
      4.75 px/char ratio: 340/4.75 ≈ 71 chars, 408/4.75 ≈ 85 chars.

  Preview:
    1. Open in JasperStudio (data adapter property is already pinned to
       "One Empty Record" via property line 4).
    2. Click Preview. The <parameter name="customers"> default supplies
       three inline sample rows of different lengths so you can SEE the
       dots adjust per row.
-->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                                  http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="Leaf_Grey_minimalist_AFTER_v2"
              pageWidth="560" pageHeight="842"
              columnWidth="552"
              leftMargin="4" rightMargin="4"
              topMargin="4" bottomMargin="4"
              uuid="aaaa0001-0000-0000-0000-000000000003">

    <property name="com.jaspersoft.studio.data.defaultdataadapter" value="One Empty Record"/>

    <!-- Mirror production: same subDataset name + uuid (faithful identity). -->
    <style name="Detail" fontName="DejaVu Sans" fontSize="12"/>

    <subDataset name="Customer" uuid="57a54224-0c83-4ebf-938d-cd455e60463a">
        <field name="customerName"    class="java.lang.String"/>
        <field name="customerAddress" class="java.lang.String"/>
    </subDataset>

    <!-- Sample data so the report previews directly under "One Empty Record". -->
    <parameter name="customers" class="java.util.Collection" isForPrompting="false">
        <defaultValueExpression><![CDATA[java.util.Arrays.asList(
            new java.util.HashMap<String,Object>() {{
                put("customerName",    "abdelaziz aguenchich");
                put("customerAddress", "1 rue Mohammed V Casablanca");
            }},
            new java.util.HashMap<String,Object>() {{
                put("customerName",    "Mohamed El Idrissi El Alami");
                put("customerAddress", "Residence Al Andalous, Rabat");
            }},
            new java.util.HashMap<String,Object>() {{
                put("customerName",    "X");
                put("customerAddress", "Y");
            }}
        )]]></defaultValueExpression>
    </parameter>

    <detail>
        <band height="40" splitType="Stretch">
            <componentElement>
                <reportElement x="0" y="0" width="552" height="40" uuid="aaaa0002-0000-0000-0000-000000000003"/>
                <jr:list xmlns:jr="http://jasperreports.sourceforge.net/jasperreports/components"
                         xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports/components
                                             http://jasperreports.sourceforge.net/xsd/components.xsd"
                         printOrder="Vertical">
                    <datasetRun subDataset="Customer" uuid="aaaa0003-0000-0000-0000-000000000003">
                        <dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.data.JRMapCollectionDataSource($P{customers})]]></dataSourceExpression>
                    </datasetRun>
                    <jr:listContents height="40" width="552">

                        <!-- ============= Bordered frame (production style="Detail" + 4-pen 1.0) ============= -->
                        <frame>
                            <reportElement style="Detail" x="0" y="0" width="552" height="40" uuid="aaaa0004-0000-0000-0000-000000000003"/>
                            <box>
                                <topPen    lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
                                <leftPen   lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
                                <bottomPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
                                <rightPen  lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
                            </box>

                            <!-- Row 2: customerAddress value field (INSIDE the frame, like production).
                                 Original production expression was just $F{customerAddress}, with a
                                 separate static dots <staticText uuid=52008247-…> overlapping behind it.
                                 Here the dots are baked into the expression and the static strip is gone.
                                 Width=408 → max_chars = floor(408/4.75) = 85. -->
                            <textField isBlankWhenNull="true">
                                <reportElement x="100" y="16" width="408" height="13" uuid="aaaa0005-0000-0000-0000-000000000003"/>
                                <box>
                                    <topPen    lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                                    <leftPen   lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                                    <bottomPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
                                    <rightPen  lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                                </box>
                                <textElement textAlignment="Left" verticalAlignment="Bottom">
                                    <font fontName="DejaVu Sans" isBold="true"/>
                                </textElement>
                                <textFieldExpression><![CDATA[($F{customerAddress} == null ? "" : $F{customerAddress}) + "........................................................................................................................................................................................................".substring(0, Math.max(3, Math.min(200, 85 - ($F{customerAddress} == null ? 0 : $F{customerAddress}.length()))))]]></textFieldExpression>
                            </textField>
                        </frame>

                        <!-- ============= French labels (OUTSIDE frame, production quirk) ============= -->

                        <textField>
                            <reportElement x="0" y="0" width="100" height="15" uuid="aaaa0006-0000-0000-0000-000000000003"/>
                            <box>
                                <leftPen   lineWidth="0.75"/>
                                <bottomPen lineWidth="1.0"/>
                            </box>
                            <textElement>
                                <font fontName="DejaVu Sans"/>
                            </textElement>
                            <textFieldExpression><![CDATA[" Nom et Prénom"]]></textFieldExpression>
                        </textField>

                        <textField>
                            <reportElement x="0" y="15" width="90" height="14" uuid="aaaa0007-0000-0000-0000-000000000003"/>
                            <box>
                                <leftPen   lineWidth="0.75"/>
                                <bottomPen lineWidth="1.0"/>
                            </box>
                            <textElement>
                                <font fontName="DejaVu Sans"/>
                            </textElement>
                            <textFieldExpression><![CDATA[" Adresse"]]></textFieldExpression>
                        </textField>

                        <!-- ============= Colons (OUTSIDE frame, production behavior) ============= -->

                        <textField>
                            <reportElement x="90" y="0" width="10" height="15" uuid="aaaa0008-0000-0000-0000-000000000003"/>
                            <textElement>
                                <font fontName="DejaVu Sans"/>
                            </textElement>
                            <textFieldExpression><![CDATA[" :"]]></textFieldExpression>
                        </textField>

                        <textField>
                            <reportElement x="90" y="15" width="10" height="14" uuid="aaaa0009-0000-0000-0000-000000000003"/>
                            <box>
                                <topPen    lineWidth="1.0"/>
                                <bottomPen lineWidth="1.0"/>
                            </box>
                            <textElement>
                                <font fontName="DejaVu Sans"/>
                            </textElement>
                            <textFieldExpression><![CDATA[" :"]]></textFieldExpression>
                        </textField>

                        <!-- ============= Arabic labels (OUTSIDE frame, right-aligned, production) ============= -->

                        <staticText>
                            <reportElement x="440" y="1" width="112" height="14" uuid="aaaa000a-0000-0000-0000-000000000003"/>
                            <box padding="0">
                                <pen       lineWidth="1.0" lineStyle="Dotted"/>
                                <topPen    lineWidth="0.0" lineStyle="Solid"/>
                                <leftPen   lineWidth="0.0" lineStyle="Solid"/>
                                <bottomPen lineWidth="1.0" lineStyle="Solid"/>
                                <rightPen  lineWidth="1.0" lineStyle="Solid"/>
                            </box>
                            <textElement textAlignment="Right" verticalAlignment="Middle">
                                <font fontName="DejaVu Sans" size="10" isBold="false" isUnderline="false"/>
                            </textElement>
                            <text><![CDATA[ الإسم العائلي و الشخصي:]]></text>
                        </staticText>

                        <staticText>
                            <reportElement x="508" y="15" width="44" height="14" uuid="aaaa000b-0000-0000-0000-000000000003"/>
                            <box padding="0">
                                <pen       lineWidth="1.0" lineStyle="Dotted"/>
                                <topPen    lineWidth="0.0" lineStyle="Solid"/>
                                <leftPen   lineWidth="0.0" lineStyle="Solid"/>
                                <bottomPen lineWidth="1.0" lineStyle="Solid"/>
                                <rightPen  lineWidth="0.0" lineStyle="Solid"/>
                            </box>
                            <textElement textAlignment="Right" verticalAlignment="Middle">
                                <font fontName="DejaVu Sans" size="10" isBold="false" isUnderline="false"/>
                            </textElement>
                            <text><![CDATA[ العنوان:]]></text>
                        </staticText>

                        <!-- ============= customerName value field (OUTSIDE frame — production quirk) =============
                             In production this field uses mode="Transparent" + markup="styled" + a tabStop at
                             position 340 alignment=Right. The tabStop becomes UNNECESSARY because we're now
                             producing the leader inline, so it's omitted. Everything else is preserved.
                             Width=340 → max_chars = floor(340/4.75) = 71.
                             -->
                        <textField isBlankWhenNull="true">
                            <reportElement mode="Transparent" x="100" y="1" width="340" height="14"
                                           forecolor="#000000" backcolor="#FFFFFF"
                                           uuid="aaaa000c-0000-0000-0000-000000000003"/>
                            <box>
                                <leftPen   lineWidth="0.0"/>
                                <bottomPen lineWidth="1.0"/>
                            </box>
                            <textElement textAlignment="Left" verticalAlignment="Middle" markup="styled">
                                <font fontName="DejaVu Sans" size="9" isBold="true"/>
                            </textElement>
                            <textFieldExpression><![CDATA[($F{customerName} == null ? "" : $F{customerName}) + "........................................................................................................................................................................................................".substring(0, Math.max(3, Math.min(200, 71 - ($F{customerName} == null ? 0 : $F{customerName}.length()))))]]></textFieldExpression>
                        </textField>

                    </jr:listContents>
                </jr:list>
            </componentElement>
        </band>
    </detail>
</jasperReport>