		<band height="130" splitType="Stretch">
			<frame>
				<reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="535" height="130" uuid="4bcdef01-2345-6789-abcd-012345679001"/>
				<frame>
					<reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="267" height="130" uuid="5cdef012-3456-789a-bcde-012345679002"/>
					<staticText>
						<reportElement x="5" y="5" width="255" height="66" uuid="6def0123-4567-89ab-cdef-012345679003"/>
						<textElement textAlignment="Justified">
							<font fontName="DejaVu Sans" size="8" isBold="true"/>
						</textElement>
						<text><![CDATA[1) Faire précéder la signature par la mention écrite de la main de la CAUTION :  « En ma qualité de Caution solidaire, je sais que je n'ai pas le droit d'exiger la discussion de l'Emprunteur, prévu par l'article 1136 du Dahir du 9 ramadan 1331 (12 août 1913) formant Code des Obligations et des Contrats et en conséquences je m'engage à rembourser la Banque, ]]></text>
					</staticText>
					<textField textAdjust="StretchHeight">
						<reportElement x="5" y="73" width="255" height="27" uuid="7ef01234-5678-9abc-def0-012345679004"/>
						<textElement>
							<font fontName="DejaVu Sans" size="8" isBold="true"/>
						</textElement>
						<textFieldExpression><![CDATA["solidairement avec Mr. ou Mrs "+$P{customerFullName}]]></textFieldExpression>
					</textField>
					<staticText>
						<reportElement x="5" y="100" width="255" height="25" uuid="8ef01234-5678-9abc-def0-012345679005"/>
						<textElement textAlignment="Justified" verticalAlignment="Middle">
							<font fontName="DejaVu Sans" size="8" isBold="true"/>
						</textElement>
						<text><![CDATA[sans exiger qu'elle le ou les poursuive préalablement ».]]></text>
					</staticText>
				</frame>
				<frame>
					<reportElement stretchType="RelativeToTallestObject" x="268" y="0" width="267" height="130" uuid="90123456-789a-bcde-f012-012345679006"/>
					<staticText>
						<reportElement x="7" y="5" width="255" height="120" uuid="a1234567-89ab-cdef-0123-012345679007"/>
						<textElement textAlignment="Right">
							<font fontName="DejaVu Sans" size="8" isBold="true"/>
						</textElement>
						<text><![CDATA[(1) يتعيــــن علـــى الموقـــع أن يسبـــق توقيعـــــه بالبيـــانـــات التاليــــة المكتـــوبة بخــــط اليــــد " بصفتــــي  كفيـــــل متضامــــــــن ، أصـــــــرح أنـــــــــه ليــــــــس مـــــــــــن حقـــــــي فـــــــــــرض المتابعـــــــة القبليــــــــــة للمقتــــــــــرض، المنصــــــــــوص عليهـــــــا فــــــــي المــــــــادة 1136 مـــــــن ظهيـــــــر 9 رمضــــــان 1331 )12 غشــــــــت 1913 المشكــــــــل لقانــــــــون الالتزامـــــــات و العقــــــــود وبالتالـــــــي فــإنــــــــي أتعهــــــــــد بـــــــــــأن أؤدي
للبنـــــــــــك تضامنــيـــا مـــع السيـــد أو الســــادة

دون إمكانيـــة فـــرض متابعــــة أو متابعتهــــم القبليــــة.]]></text>
					</staticText>
				</frame>
			</frame>
		</band>
