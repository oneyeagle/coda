				<frame>
					<reportElement x="0" y="0" width="267" height="90" uuid="97ff9037-0a03-423a-b038-a81503eefbd5"/>
					<box>
						<topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
						<rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					</box>
					<staticText>
						<reportElement x="5" y="5" width="255" height="80" uuid="66bad452-6681-4155-836d-a91d98a6b9a9"/>
						<textElement textAlignment="Justified">
							<font fontName="DejaVu Sans" size="9"/>
						</textElement>
						<text><![CDATA[notamment des conditions générales et particulières dudit contrat, se porter CAUTION SOLIDAIRE et personnelle et s'engage à ce titre envers la Banque à garantir en cette qualité le remboursement en cas de défaillance de l'Emprunteur de toutes sommes que ce dernier doit ou devra à la Banque à quelque titre et pour quelque cause que ce soit
]]></text>
					</staticText>
				</frame>
				<frame>
					<reportElement x="268" y="0" width="267" height="90" uuid="4fb91402-7bde-47d8-b4bd-047442185708"/>
					<staticText>
						<reportElement x="7" y="0" width="255" height="80" uuid="2fbbf0e0-9a05-40e0-b527-b93668b24fbd">
							<property name="com.jaspersoft.studio.unit.y" value="px"/>
						</reportElement>
						<textElement textAlignment="Right">
							<font fontName="DejaVu Sans" size="9"/>
						</textElement>
						<text><![CDATA[
و كذا الشروط العامة و الخاصة لهذا العقد , و أنه يكفل تضامنيا و شخصيا و  يلتزم اتجاه البنك بضمان تسديد كل المبالغ التي سيكون المقترض مدينا بها اتجاه البنك , كيفما كان توعها و لأي سبب كانت  في حالة تقصير هذا الأخير ,
]]></text>
					</staticText>
				</frame>
			</frame>
		</band>
		<band height="40" splitType="Stretch">
			<frame>
				<reportElement x="0" y="0" width="535" height="40" uuid="49be9638-161b-4d9b-bd34-0c1db9a07a92"/>
				<staticText>
					<reportElement x="390" y="0" width="142" height="14" uuid="67ff70ba-615d-4e2d-91e1-d5bb12f341d5"/>
					<textElement textAlignment="Right">
						<font fontName="DejaVu Sans" size="9"/>
					</textElement>
					<text><![CDATA[فـــــي حــــــدود مبلغ الرأسمال :]]></text>
				</staticText>
				<staticText>
					<reportElement x="5" y="0" width="195" height="14" uuid="54644c48-8184-43d3-9afd-c8efb0c51b2f"/>
					<textElement>
