                    </box>
                    <staticText>
                        <reportElement x="5" y="5" width="255" height="80" uuid="d0e1f2a3-b4c5-4131-7f8a-9b0c1d2e3f4a"/>
                        <textElement>
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[- qu'il n'existe sur la (ou les) propriété(s) hypothéquée(s) ni clause de résolution ou de rescision, ni de servitude, ni droits coutumiers musulmans, ni opposition, ni hypothèque, demande d'hypothèque conventionnelle ou forcée, ni prénotation, ni aucun droit de nature à porter atteinte à l'hypothèque ci-dessus consentie.]]></text>
                    </staticText>
                </frame>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="268" y="0" width="267" height="90" uuid="f2a3b4c5-d6e7-4133-9b0c-1d2e3f4a5b6c"/>
                    <staticText>
                        <reportElement x="7" y="5" width="255" height="80" uuid="a3b4c5d6-e7f8-4134-0c1d-2e3f4a5b6c7d"/>
                        <textElement textAlignment="Right">
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[- أنـــه لا يــوجـــد علـــى الملكيـــة أو الأمـــلاك المرهونـــة أي شـــرط فاســـــخ أو مبطــــــل، ولا أي ارتفــاقـــات، ولا أي حقـــــــوق عرفيـــــــة إسلاميــــة، كمـــا لا يــوجـــد أي تعــــرض أو رهـــــن رسمـــــي أو طلــــــــب رهــــــن رسمـــي اتفاقـــــي أو إجباري، ولا أي تقييــــــد احتياطــــي، أو أي حــــــق مـــــــن شأنـــــــه أن يمـــــــس بالــــرهـــــن الرسمـــــي المنصوص عليه أعـــــلاه]]></text>
                    </staticText>
                </frame>
            </frame>
        </band>
