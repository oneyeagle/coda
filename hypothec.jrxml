                        <bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
                    </box>
                    <staticText>
                        <reportElement x="5" y="5" width="255" height="75" uuid="d4e5f6a7-b8c9-4125-1f2a-3b4c5d6e7f8a"/>
                        <textElement>
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[L'Emprunteur déclare :
- que les immeubles par destination dépendant de la (ou des) propriété(s) désignée(s) ci-après ne sont pas nantis au profit d'un autre créancier et il s'engage expressément à ne pas les nantir sans l'autorisation expresse et par écrit de la Banque,]]></text>
                    </staticText>
                </frame>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="268" y="0" width="267" height="85" uuid="f6a7b8c9-d0e1-4127-3b4c-5d6e7f8a9b0c"/>
                    <staticText>
                        <reportElement x="7" y="5" width="255" height="75" uuid="a7b8c9d0-e1f2-4128-4c5d-6e7f8a9b0c1d"/>
                        <textElement textAlignment="Right">
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[يصرح المقترض :
- بــــأن البنــايــات التابعـــــة بالتخصيــص للملكيــــــة أو الأمـــلاك المعينــــة بعــــــده غيـــــر مــرهـــونـــة لفـــائــــدة دائــــــن آخــــــر، ويتعهــــــد صراحـــة بعــــــدم رهنهــــــا بـــدون موافقـــــــة صريحــة ومكتوبـــة مــن البنـــك؛]]></text>
                    </staticText>
                </frame>
            </frame>
        </band>
        <band height="90" splitType="Stretch">
            <frame>
                <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="535" height="90" uuid="b8c9d0e1-f2a3-4129-5d6e-7f8a9b0c1d2e"/>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="267" height="90" uuid="c9d0e1f2-a3b4-4130-6e7f-8a9b0c1d2e3f"/>
                    <box>
                        <topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
