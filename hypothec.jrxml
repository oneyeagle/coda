                                        <text><![CDATA[يمنـــح المقتــــرض طبقـــــا لمقتضيـــات ظهيـــــر 22 نوفمبر 2011، لفائـــــدة البنـــك الــــذي يقبـــــل بالامتيــــــاز وبالأفضليـــــة علـــــى كـــل دائــــــن آخـــــر رهنـا رسميـا مــن الدرجـة]]></text>
                                    </staticText>
                                </frame>
                            </frame>
                        </jr:listContents>
                    </jr:list>
                </componentElement>
            </frame>
        </band>
        <band height="20" splitType="Stretch">
            <frame>
                <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="535" height="20" uuid="b8c9d0e1-f2a3-4069-5d6e-7f8a9b0c1d2e"/>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="267" height="20" uuid="c9d0e1f2-a3b4-4070-6e7f-8a9b0c1d2e3f"/>
                    <textField textAdjust="StretchHeight">
                        <reportElement x="5" y="5" width="255" height="15" uuid="d0e1f2a3-b4c5-4071-7f8a-9b0c1d2e3f4a"/>
                        <textElement>
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <textFieldExpression><![CDATA["à concurrence d'un montant " + ($P{loanAmount} != null ? $P{loanAmount} : "")]]></textFieldExpression>
                    </textField>
                </frame>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="268" y="0" width="267" height="20" uuid="f2a3b4c5-d6e7-4073-9b0c-1d2e3f4a5b6c"/>
                    <staticText>
                        <reportElement x="7" y="5" width="255" height="15" uuid="a3b4c5d6-e7f8-4074-0c1d-2e3f4a5b6c7d"/>
                        <textElement textAlignment="Right">
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[فـي حـدود مبلغ أصل الدين]]></text>
                    </staticText>
                </frame>
            </frame>
        </band>
        <band height="100" splitType="Stretch">
            <frame>
                <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="535" height="100" uuid="b4c5d6e7-f8a9-4075-1d2e-3f4a5b6c7d8e"/>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="267" height="100" uuid="c5d6e7f8-a9b0-4076-2e3f-4a5b6c7d8e9f"/>
                    <box>
                        <topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
                    </box>
                    <staticText>
                        <reportElement x="5" y="5" width="255" height="90" uuid="d6e7f8a9-b0c1-4077-3f4a-5b6c7d8e9f0a"/>
                        <textElement>
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[en capital outre les intérêts, commissions, frais et accessoires, sur le (ou les) immeuble(s) désigné(s) ci-après pour garantir tant le remboursement du montant du présent crédit en capital ainsi que le paiement des intérêts d'une année et de l'année courante en vertu de l'article 168 du Dahir précité.]]></text>
                    </staticText>
                </frame>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="268" y="0" width="267" height="100" uuid="f8a9b0c1-d2e3-4079-5b6c-7d8e9f0a1b2c"/>
                    <staticText>
                        <reportElement x="7" y="5" width="255" height="90" uuid="a9b0c1d2-e3f4-4080-6c7d-8e9f0a1b2c3d"/>
                        <textElement textAlignment="Right">
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[رأسمــــــالا بالإضافـــــــة إلــــــى الفـــــوائــــــد، العمــــــــولات، المصـــاريــف والتـــوابـــــــع علــــــى مجمـــــــــوع العقــــــــار أو العقــــــارات المعينـــــــة فيمـــــا يلـــــي، مـــــن أجــــــل ضمــــان تســــديـــــد مبلــــغ رأسمــــال هـــــذا القــــــرض بالإضافــــة إلــــى تســـديـــــد الفـــــوائـــــــد لسنــــــة واحــــدة وللسنــــــة الجاريــة طبقـــــا لمقتضيـــات المــادة 168 مـن الظهيــــر السالــف الــذكــر.]]></text>
                    </staticText>
                </frame>
            </frame>
        </band>
        <band height="100" splitType="Stretch">
            <frame>
                <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="535" height="100" uuid="b0c1d2e3-f4a5-4081-7d8e-9f0a1b2c3d4e"/>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="267" height="100" uuid="c1d2e3f4-a5b6-4082-8e9f-0a1b2c3d4e5f"/>
                    <box>
                        <topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
                    </box>
                    <staticText>
                        <reportElement x="5" y="5" width="255" height="90" uuid="d2e3f4a5-b6c7-4083-9f0a-1b2c3d4e5f6a"/>
                        <textElement>
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[Sont compris dans l'affectation hypothécaire, les biens immobiliers ci-après désignés, tels qu'ils existent, y compris toutes dépendances, toutes les constructions qui seront édifiées, tous droits y attachés, tous immeubles par destination en dépendant ou pouvant en dépendre et toutes améliorations et accroissements que l'Emprunteur pourra faire.]]></text>
                    </staticText>
                </frame>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="268" y="0" width="267" height="100" uuid="f4a5b6c7-d8e9-4085-1b2c-3d4e5f6a7b8c"/>
                    <staticText>
                        <reportElement x="7" y="5" width="255" height="90" uuid="a5b6c7d8-e9f0-4086-2c3d-4e5f6a7b8c9d"/>
                        <textElement textAlignment="Right">
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[ويدخـــــل ضمــــن التخصيــــص الرهنــــي، المـــلك أو الممتلكـــــات العقاريـــــة المعينـــــة أسفله، كمـا هـــي موجــــودة، بمــــا فيهــــا جميــــع المرافـــق وكـــل البنــاءات التـــي سيتــم   شييــدها، وكـل الحقــــوق المرتبطـــة بهــــا، وكــل العقـــارات التابعـــة لهـا بالتخصيــص أو التــي يمكــن أن تصبـــح تابعـــة لهـــا، وكـــــذا جميــــع التحسينــــات والإضــافات التـــي يمكـــن للمقتـــرض أن يدخلهــــا عليهــــا.]]></text>
                    </staticText>
                </frame>
            </frame>
        </band>
        <band height="90" splitType="Stretch">
            <frame>
                <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="535" height="90" uuid="b6c7d8e9-f0a1-4087-3d4e-5f6a7b8c9d0e"/>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="267" height="90" uuid="c7d8e9f0-a1b2-4088-4e5f-6a7b8c9d0e1f"/>
                    <box>
                        <topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
                    </box>
                    <staticText>
                        <reportElement x="5" y="5" width="255" height="80" uuid="d8e9f0a1-b2c3-4089-5f6a-7b8c9d0e1f2a"/>
                        <textElement>
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[L'Emprunteur s'engage à maintenir les constructions en bon état et à effectuer toutes les réparations nécessaires à la conservation des immeubles, la Banque pourra à toute époque faire constater l'état des biens hypothéqués par les personnes de son choix aux frais de l'Emprunteur qui s'y oblige.]]></text>
                    </staticText>
                </frame>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="268" y="0" width="267" height="90" uuid="f0a1b2c3-d4e5-4091-7b8c-9d0e1f2a3b4c"/>
                    <staticText>
                        <reportElement x="7" y="5" width="255" height="80" uuid="a1b2c3d4-e5f6-4092-8c9d-0e1f2a3b4c5d"/>
                        <textElement textAlignment="Right">
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[يلتــــــزم المقتــــــــرض بالمحافظـــــة علـــى البنـــايـــات فـــي حـــالــة جيــــــدة وبالقيــــــام بكــــافـــــــة الإصـــلاحـــــات الضروريـــة للحفــــــــاظ علـــــــى العقــــــارات، حيــــــث يمكـــن للبنــــــك فــــــي أيــــــة لحظــــــة القيـــــام بمعاينــــــة حالـــــــة الأمــــــلاك المرهـــونــــة بواسطــــــة أشخــــــاص مــــــن اختيــــــاره علـــى نفقــــــة المقتـــرض الــــذي يلتــــــزم بـــــــذلك.]]></text>
                    </staticText>
                </frame>
            </frame>
        </band>
        <band height="65" splitType="Stretch">
            <frame>
                <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="535" height="65" uuid="b2c3d4e5-f6a7-4093-9d0e-1f2a3b4c5d6e"/>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="267" height="65" uuid="c3d4e5f6-a7b8-4094-0e1f-2a3b4c5d6e7f"/>
                    <box>
                        <topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
                    </box>
                    <staticText>
                        <reportElement x="5" y="5" width="255" height="55" uuid="d4e5f6a7-b8c9-4095-1f2a-3b4c5d6e7f8a"/>
                        <textElement>
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[L'Emprunteur s'interdit d'affecter l'(ou les) immeuble(s) hypothéqué(s) en faveur de la Banque à un usage commercial, de le rattacher à un fonds de commerce ou d'y constituer un fonds de commerce.]]></text>
                    </staticText>
                </frame>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="268" y="0" width="267" height="65" uuid="f6a7b8c9-d0e1-4097-3b4c-5d6e7f8a9b0c"/>
                    <staticText>
                        <reportElement x="7" y="5" width="255" height="55" uuid="a7b8c9d0-e1f2-4098-4c5d-6e7f8a9b0c1d"/>
                        <textElement textAlignment="Right">
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[يمتنـــع المقتـــرض عـــن تخصيـــص العقــــار أو العقــــارات المرهونــــة رسميـــا لفـــائــــدة البنــــك للاستعمــــال التجــــاري، أو إلحـــاقهــــا بأصـــل تجـــــاري أو تأسيس أصــل تجــاري عليهــا، بـــدون المــوافقـــة المسبقــة والمكتــوبة مـــن البنـــك.]]></text>
                    </staticText>
                </frame>
            </frame>
        </band>
        <band height="55" splitType="Stretch">
            <frame>
                <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="535" height="55" uuid="b8c9d0e1-f2a3-4099-5d6e-7f8a9b0c1d2e"/>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="267" height="55" uuid="c9d0e1f2-a3b4-4100-6e7f-8a9b0c1d2e3f"/>
                    <box>
                        <topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
                    </box>
                    <staticText>
                        <reportElement x="5" y="5" width="255" height="45" uuid="d0e1f2a3-b4c5-4101-7f8a-9b0c1d2e3f4a"/>
                        <textElement>
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[L'Emprunteur s'interdit de donner en location l'(ou les) immeuble(s) hypothéqué(s) en faveur de la Banque sans accord préalable et écrit de cette dernière.]]></text>
                    </staticText>
                </frame>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="268" y="0" width="267" height="55" uuid="f2a3b4c5-d6e7-4103-9b0c-1d2e3f4a5b6c"/>
                    <staticText>
                        <reportElement x="7" y="5" width="255" height="45" uuid="a3b4c5d6-e7f8-4104-0c1d-2e3f4a5b6c7d"/>
                        <textElement textAlignment="Right">
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[يمتنــع المقتـــرض عــن منـــح العقـــار أو العقــارات المرهــونــة رسميــا لفائــدة البنــك علــى سبيـــل الكـــراء، بــــدون المـــوافقــة المسبقـــة والمكتوبـــة مـــن البنــــك.]]></text>
                    </staticText>
                </frame>
            </frame>
        </band>
        <band height="75" splitType="Stretch">
            <frame>
                <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="535" height="75" uuid="b4c5d6e7-f8a9-4105-1d2e-3f4a5b6c7d8e"/>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="267" height="75" uuid="c5d6e7f8-a9b0-4106-2e3f-4a5b6c7d8e9f"/>
                    <box>
                        <topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
                    </box>
                    <staticText>
                        <reportElement x="5" y="5" width="255" height="65" uuid="d6e7f8a9-b0c1-4107-3f4a-5b6c7d8e9f0a"/>
                        <textElement>
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[En cas de location dûment autorisée par la Banque, l'Emprunteur déclare d'ores et déjà céder, déléguer et transporter au profit de la Banque tous loyers et revenus de l'(ou les) immeuble (s) grevé (s) d'hypothèque.]]></text>
                    </staticText>
                </frame>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="268" y="0" width="267" height="75" uuid="f8a9b0c1-d2e3-4109-5b6c-7d8e9f0a1b2c"/>
                    <staticText>
                        <reportElement x="7" y="5" width="255" height="65" uuid="a9b0c1d2-e3f4-4110-6c7d-8e9f0a1b2c3d"/>
                        <textElement textAlignment="Right">
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[فــي حالـــة كــــراء مــرخـص بـــه كتابـــة مـــن طـــرف البنــــك،يصـــرح المقتـــرض، منــــــذ الآن، بتفـــويــت وإنابــــة ونقــل جميـــع أكريــــة ومداخيـــل العقـــارأو العقـــارات المثقلــــة بالرهـــون الرسميـــة، لفــائـــدة البنـــك.]]></text>
                    </staticText>
                </frame>
            </frame>
        </band>
        <band height="100" splitType="Stretch">
            <frame>
                <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="535" height="100" uuid="b0c1d2e3-f4a5-4111-7d8e-9f0a1b2c3d4e"/>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="267" height="100" uuid="c1d2e3f4-a5b6-4112-8e9f-0a1b2c3d4e5f"/>
                    <box>
                        <topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
                    </box>
                    <staticText>
                        <reportElement x="5" y="5" width="255" height="90" uuid="d2e3f4a5-b6c7-4113-9f0a-1b2c3d4e5f6a"/>
                        <textElement>
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[En conséquence, il subroge la Banque dans tous ses droits et actions vis à vis de ses locataires, lesquels sont autorisés à se libérer de tous loyers directement entre les mains de la Banque par préférence et antériorité à tous autres créanciers et à lui-même sur simple quittance de celle-ci et hors la présence de l'Emprunteur.]]></text>
                    </staticText>
                </frame>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="268" y="0" width="267" height="100" uuid="f4a5b6c7-d8e9-4115-1b2c-3d4e5f6a7b8c"/>
                    <staticText>
                        <reportElement x="7" y="5" width="255" height="90" uuid="a5b6c7d8-e9f0-4116-2c3d-4e5f6a7b8c9d"/>
                        <textElement textAlignment="Right">
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[ونتيجــة لــذلك، فإن البنـــك يحـــل محلـــه فــي جميـــع حقوقـــه ودعـــاواه تجـــاه مكتريـــه، ويعتبـــر هــؤلاء المكتريـــن مخـــوليـــن صراحـــة بمقتـــضى هـــذا العقــــد، بــــأداء الأكريـــة مباشـــرة بيـــن يــــدي البنـــك بالأفضليـــة وبالأسبقيـــة علـــى جميــــع الدائنيـــن الآخريــــن بــــل وبالأسبقيـــة عليـــه هـــو نفســـــه بنــــاء علـــى مجــــرد وصــــل مــــن هــــذا البنــــك وفــــي غيــــاب المقـــــترض.]]></text>
                    </staticText>
                </frame>
            </frame>
        </band>
        <band height="90" splitType="Stretch">
            <frame>
                <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="535" height="90" uuid="b6c7d8e9-f0a1-4117-3d4e-5f6a7b8c9d0e"/>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="267" height="90" uuid="c7d8e9f0-a1b2-4118-4e5f-6a7b8c9d0e1f"/>
                    <box>
                        <topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <leftPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <bottomPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
                        <rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
                    </box>
                    <staticText>
                        <reportElement x="5" y="5" width="255" height="80" uuid="d8e9f0a1-b2c3-4119-5f6a-7b8c9d0e1f2a"/>
                        <textElement>
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[Néanmoins, notification de cette délégation et de cette subrogation ne sera faite aux locataires qu'en cas de défaut de paiement de toutes sommes dues et exigibles en capital, intérêts, commissions, frais et accessoires à quelque titre et pour quelque cause que ce soit ou en cas d'inexécution de l'une des clauses et conditions du présent contrat.]]></text>
                    </staticText>
                </frame>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="268" y="0" width="267" height="90" uuid="f0a1b2c3-d4e5-4121-7b8c-9d0e1f2a3b4c"/>
                    <staticText>
                        <reportElement x="7" y="5" width="255" height="80" uuid="a1b2c3d4-e5f6-4122-8c9d-0e1f2a3b4c5d"/>
                        <textElement textAlignment="Right">
                            <font fontName="DejaVu Sans" size="10"/>
                        </textElement>
                        <text><![CDATA[إلا أن تبليــــــــغ هـــــــــذه الإنابـــــــــة إلــــــى المكتريـــــن،وحلــــــول البنــــــــــك محــــــــــل المقتــــــــــر، لــــن يتـــــــــم إلا فـــــــي حالـــــــــة عـــــــــــدم أداء المبالـــــغ المستحقـــــــة والتــــي حـــــــل أجلهـــــــا رأسمــــــــــالا وفـــــوائــــــد وعمـــــــولات ومصاريـــــــف وتوابـــع، لأي سبـــــب كـــــان، أو في حالــــة عــــدم تنفيــــذ أحـــد بنـــــود أو شــــروط هـــذا العـقــــد.]]></text>
                    </staticText>
                </frame>
            </frame>
        </band>
        <band height="85" splitType="Stretch">
            <frame>
                <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="535" height="85" uuid="b2c3d4e5-f6a7-4123-9d0e-1f2a3b4c5d6e"/>
                <frame>
                    <reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="267" height="85" uuid="c3d4e5f6-a7b8-4124-0e1f-2a3b4c5d6e7f"/>
                    <box>
                        <topPen lineWidth="0.0" lineStyle="Solid" lineColor="#000000"/>
